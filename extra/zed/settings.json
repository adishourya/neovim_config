{
  // Non Buffer stuff
  "auto_update": true, // hmm.. we will see
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  }, // default both "on"
  "confirm_quit": true,
  "format_on_save": "on", // idc
  "formatter": "language_server",
  // UI Stuff
  "tab_bar": {
    "show": false // no thankyou
  },
  "git_status": true,
  "show_whitespaces": "selection",
  "indent_guides": {
    "enabled": true
  },
  "enable_language_server": true, // sometimes no.
  "project_panel": {
    "button": true,
    "default_width": 240,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "scrollbar": {
      "show": "always"
    }
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true
  },
  "scrollbar": {
    "show": "never",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "diagnostics": true
  },
  // "current_line_highlight": "line",
  "current_line_highlight": "none",
  "buffer_font_family": "Geist Mono",
  "buffer_font_features": {
    "calt": true
  }, // force enable ligatures
  "buffer_line_height": {
    "custom": 2.5
  }, // higher <=> more spacing
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Summercamp"
  },
  // Rest
  "assistant": {
    "enabled": false, // no thanyou!
    "version": "2"
  },
  "vim_mode": true,
  "relative_line_numbers": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },
  "jupyter": {
    "kernel_selections": {
      "python": "python3"
    }
  }
}
